{
  "highlightStyles": [
    {
      "style": "default",
      "rules": [
        {
          "patterns": [
            {
              "regexp": "\\b[+-]?[.0-9]+(?:[eEdD][+-]?[.0-9]+)?\\b"
            }
          ],
          "format": {
            "preset": "literal"
          }
        },
        {
          "patterns": [
            {
              "regexp": "\\\\bAIDER\\\\b"
            },
            {
              "regexp": "\\\\bAIGIN\\\\b"
            },
            {
              "regexp": "\\\\bAIGOUT\\\\b"
            },
            {
              "regexp": "\\\\bALLBONDS\\\\b"
            },
            {
              "regexp": "\\\\bALLVEC\\\\b"
            },
            {
              "regexp": "\\\\bALT_A\\\\b"
            },
            {
              "regexp": "\\\\bALT_R\\\\b"
            },
            {
              "regexp": "\\\\bAM1\\\\b"
            },
            {
              "regexp": "\\\\bAUTOSYM\\\\b"
            },
            {
              "regexp": "\\\\bAM1\\\\b"
            },
            {
              "regexp": "\\\\bBANANA\\\\b"
            },
            {
              "regexp": "\\\\bBAR\\\\b"
            },
            {
              "regexp": "\\\\bBCC\\\\b"
            },
            {
              "regexp": "\\\\bBIGCYCLES\\\\b"
            },
            {
              "regexp": "\\\\bBIRADICAL\\\\b"
            },
            {
              "regexp": "\\\\bBFGS\\\\b"
            },
            {
              "regexp": "\\\\bBONDS\\\\b"
            },
            {
              "regexp": "\\\\bBZ\\\\b"
            },
            {
              "regexp": "\\\\bPM3\\\\b"
            }
          ],
          "format": {
            "preset": "keyword"
          },
          "case_insensitive": true
        }
        {
          "patterns": [
            {
              "regexp": "\\*\\s+library\\s+([^\\n]+)"
            },
            {
              "regexp": "\\*\\s+library\\s+([^\\n]+)"
            },
            {
              "regexp": "\\*\\s+library\\s+([^\\n]+)"
            },
            {
              "regexp": "units\\s+(an|angstroms|au|atom|bohr|nm|nanometers|pm|picometers)"
            },
          ],
          "format": {
            "preset": "property"
          }
        },
        {
          "patterns": [
            {
              "regexp": "title\\s+\"(.+)\""
            }
          ],
          "format": {
            "preset": "title"
          }
        },
        {
          "patterns": [
            {
              "regexp": "#[^\n]*"
            }
          ],
          "format": {
            "preset": "comment"
          }
        }
      ]
    }
  ]
}
